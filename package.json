{
  "name": "claim-detective",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Где ложь? Симулятор детектива — data-driven insurance-investigation game for Yandex Games.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "metrika:goals": "node scripts/upload-metrica-goals.mjs",
    "metrika:goals:publish": "node scripts/upload-metrica-goals.mjs --apply",
    "playtest:validate": "node scripts/synthetic-playtest.mjs --validate",
    "playtest:run": "node scripts/synthetic-playtest.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.5.0",
    "framer-motion": "^12.40.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.61.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
